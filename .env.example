# Database (Supabase Postgres — use transaction pooler for runtime, direct URL for migrations)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="<32-char-random-string>"

# Google OAuth (optional — omit both to disable Google sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe (use test keys for development)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Create a recurring price in Stripe Dashboard at €35/month and paste the price ID here
STRIPE_SUBSCRIPTION_PRICE_ID="price_..."

# Resend (email delivery)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Upstash Redis (rate limiting — create a free database at upstash.com)
UPSTASH_REDIS_REST_URL="https://<your-db>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="<your-token>"

# Supabase Storage (animal photos)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key-from-supabase-settings>"

# Cara platform fee — Stripe Payment Link shown to adopters after signing a contract
NEXT_PUBLIC_CARA_PLATFORM_FEE_URL="https://buy.stripe.com/..."

# Cron job authentication — generate with: openssl rand -base64 32
# Vercel sends this automatically as "Authorization: Bearer <value>" to cron routes.
# For local testing, pass ?secret=<value> as a query param instead.
CRON_SECRET="<random-secret>"
